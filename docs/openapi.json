  "paths": {
    "/bpom/check/{registration_no}": {
      "get": {
        "tags": [
          "bpom"
        ],
        "summary": "Look up a BPOM product by registration number",
        "description": "Fetch a single BPOM product registration record.\n\n- **registration_no**: e.g. `BPOM MD 123456789012` or `MD 123456789012`\n- **debug**: Set to `true` to include raw scraped HTML fields",
        "operationId": "check_bpom_bpom_check__registration_no__get",
        "parameters": [
          {
            "name": "registration_no",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Registration No"
            }
          },
          {
            "name": "debug",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean",
              "description": "Include raw scraped data in response",
              "default": false,
              "title": "Debug"
            },
            "description": "Include raw scraped data in response"
          },
          {
            "name": "proxy_url",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Optional proxy URL for IP rotation",
              "title": "Proxy Url"
            },
            "description": "Optional proxy URL for IP rotation"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CivicStackResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
