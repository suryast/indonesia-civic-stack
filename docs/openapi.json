  "components": {
    "schemas": {
      "CivicStackResponse": {
        "properties": {
          "result": {
            "anyOf": [
              {
                "additionalProperties": true,
                "type": "object"
              },
              {
                "type": "null"
              }
            ],
            "title": "Result",
            "description": "Normalized domain object. Schema is module-specific and documented per module."
          },
          "found": {
            "type": "boolean",
            "title": "Found",
            "description": "True if a record was located for the query."
          },
          "status": {
            "$ref": "#/components/schemas/RecordStatus",
            "description": "Canonical status of the located record, or NOT_FOUND / ERROR."
          },
          "confidence": {
            "type": "number",
            "maximum": 1.0,
            "minimum": 0.0,
            "title": "Confidence",
            "description": "Scraper confidence in result accuracy. 1.0 = verified exact match."
          },
          "source_url": {
            "type": "string",
            "title": "Source Url",
            "description": "The canonical government URL this data was retrieved from."
          },
          "fetched_at": {
            "type": "string",
            "format": "date-time",
            "title": "Fetched At",
            "description": "Timestamp of this specific fetch (UTC)."
          },
          "last_updated": {
            "anyOf": [
              {
                "type": "string",
                "format": "date-time"
              },
              {
                "type": "null"
              }
            ],
            "title": "Last Updated",
            "description": "Last known update date from the source portal, if available."
          },
          "module": {
            "type": "string",
            "title": "Module",
            "description": "Module identifier, e.g. 'bpom', 'ahu', 'bpjph'."
          },
          "raw": {
            "anyOf": [
              {
                "additionalProperties": true,
                "type": "object"
              },
              {
                "type": "null"
              }
            ],
            "title": "Raw",
            "description": "Raw scraped data before normalization. Only included when debug=True."
          }
        },
        "type": "object",
        "required": [
          "found",
          "status",
          "confidence",
          "source_url",
          "fetched_at",
          "module"
        ],
        "title": "CivicStackResponse",
        "description": "Normalized response envelope returned by every module.\n\nConsumers should key on `found` and `status` before reading `result`.\nThe `raw` field is only populated when the caller passes debug=True."
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "RecordStatus": {
        "type": "string",
        "enum": [
          "ACTIVE",
          "EXPIRED",
          "SUSPENDED",
          "REVOKED",
          "NOT_FOUND",
          "ERROR"
        ],
        "title": "RecordStatus"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          },
          "input": {
            "title": "Input"
          },
          "ctx": {
            "type": "object",
            "title": "Context"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      }
    }
  }
